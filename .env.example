DATABASE_URL=postgres://weave:weave@localhost:5432/weave
REDIS_URL=redis://127.0.0.1:6379
API_BIND=0.0.0.0:8080
WEAVE_API_KEY=
# Required to import party + sync D&D Beyond game log (rolls) into Weave memory
DDB_COBALT_SESSION=
DATA_DIR=./data
# Parallel background jobs (STT per audio chunk; agent ticks serialized per session)
WORKER_CONCURRENCY=4
# Seconds between automatic agent condense runs after new transcript (default 25)
AGENT_DEBOUNCE_SEC=25
# Transcript lines (STT chunks) per chronicle chapter (default 30)
CHRONICLE_STT_PER_CHAPTER=30

# Agent: cursor (default in Docker; CLI baked in image) | langgraph (OpenAI) | stub
# Docker: set CURSOR_API_KEY. Compose uses CURSOR_WORKSPACE=/app/repo inside the container.
CURSOR_API_KEY=
AGENT_BACKEND=cursor
CURSOR_AGENT_MODE=ask
CURSOR_AGENT_BIN=agent
# Host dev path; Docker Compose overrides to /app/repo
CURSOR_WORKSPACE=/home/wardn/dev/weave

# Optional: OpenAI only needed for langgraph backend or cloud STT/TTS
OPENAI_API_KEY=
# auto | local (faster-whisper) | cloud (OpenAI Whisper API)
STT_PROVIDER=auto
WHISPER_MODEL=small
AGENT_MODEL=gpt-4o-mini

# Web UI: mic chunk length in milliseconds (default 4000)
VITE_AUDIO_CHUNK_MS=4000
